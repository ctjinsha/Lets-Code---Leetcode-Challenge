class Solution:
    def leftRightDifference(self, nums: list[int]) -> list[int]:
        result = []
        left_sum = 0
        right_sum = sum(nums)
        for num in nums:
            right_sum -= num
            difference = abs(left_sum - right_sum)
            result.append(difference)
            
            left_sum += num
            
    
        return result
